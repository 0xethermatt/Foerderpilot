# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Private (server-side only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Dev defaults ──────────────────────────────────────────────────────────────
# UUID of the default company created by supabase/seed.sql.
# Override if you use a different company ID in your DB.
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000001

# ─── AI Provider ───────────────────────────────────────────────────────────────
# Optional. If not set, MockAIProvider is used (no API calls, no costs).
# Set AI_PROVIDER=anthropic and supply ANTHROPIC_API_KEY to use Claude.
# AI_MODEL defaults to claude-sonnet-4-6 when provider=anthropic.
#
# SECURITY: ANTHROPIC_API_KEY is server-side only (Server Actions).
#           Never prefix it with NEXT_PUBLIC_.
#
ANTHROPIC_API_KEY=
AI_PROVIDER=mock
AI_MODEL=claude-sonnet-4-6
